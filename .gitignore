.vscode/
.idea/
*.swp
*.swo
*~

# Fly
.fly/
fly.toml.backup

# Docker
.dockerignore.backup

# SQLite (local dev DBs)
*.db
*.sqlite
*.sqlite3
*.db-shm
*.db-wal
!docs/**/*.db

# Session artifacts (dev-mode local sessions)
/workspace/
.claude/sessions/

# Spike outputs (keep the scripts, ignore captured artifacts)
spikes/**/*.jsonl.bak
spikes/**/*.log

# Claude Code local state (if any devs run claude inside the repo)
.claude/
