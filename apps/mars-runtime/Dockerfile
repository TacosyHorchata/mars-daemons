# Mars runtime container
# ----------------------
# One Fly machine per Mars workspace runs this image. The supervisor
# (FastAPI, see ``src/supervisor.py``) owns a pool of ``claude -p``
# subprocesses and forwards events back to the control plane via
# HttpEventForwarder.
#
# Single-stage on purpose — the image needs both Python 3.11 (for the
# supervisor) and Node 20 (for the pinned Claude Code CLI). The image
# hovers under 500 MB; multi-stage does not buy us much because the
# Node dependency dominates the layer weight.
#
# Pinning
# -------
# * Claude Code CLI: ``CLAUDE_CODE_VERSION`` build arg. Default matches
#   ``apps/mars-runtime/src/session/claude_code_version.py`` — bumping
#   one and not the other breaks the contract test.
# * Python deps: pinned in the RUN pip install below so rebuilds are
#   deterministic without needing to commit a lockfile.
#
# Environment contract
# --------------------
# The container expects:
# * ``PORT`` — HTTP port the supervisor binds (default 8080).
# * ``CLAUDE_CODE_OAUTH_TOKEN`` — long-lived token generated by
#   ``claude setup-token`` on Pedro's host once. Passed via ``fly secrets``.
# * ``MARS_EVENT_SECRET`` — shared secret between runtime forwarder and
#   control plane ingest.
# * ``MARS_CONTROL_URL`` — base URL of the control plane (set by
#   ``mars deploy`` at machine creation time).
#
# None of these are baked into the image.

FROM python:3.11-slim

ARG CLAUDE_CODE_VERSION=2.1.101

LABEL org.opencontainers.image.source="https://github.com/TacosyHorchata/mars-daemons"
LABEL org.opencontainers.image.title="mars-runtime"
LABEL org.opencontainers.image.description="Mars daemon host — one per workspace, runs Claude Code sessions."

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    DEBIAN_FRONTEND=noninteractive

# --- System deps + Node 20 + pinned Claude Code CLI -------------------------
# tini for clean SIGTERM forwarding to child processes. ca-certificates
# + curl + gnupg are needed only to set up the Node repo, then purged.
RUN set -eux; \
    apt-get update; \
    apt-get install -y --no-install-recommends \
        ca-certificates \
        curl \
        gnupg \
        tini; \
    curl -fsSL https://deb.nodesource.com/setup_20.x | bash -; \
    apt-get install -y --no-install-recommends nodejs; \
    npm install -g "@anthropic-ai/claude-code@${CLAUDE_CODE_VERSION}"; \
    claude --version; \
    apt-get purge -y --auto-remove curl gnupg; \
    rm -rf /var/lib/apt/lists/* /tmp/* /var/tmp/* /root/.npm

# --- Python deps ------------------------------------------------------------
# Kept in sync with root pyproject.toml. Bump both together.
RUN pip install --no-cache-dir \
        "click>=8.1,<9" \
        "fastapi>=0.135,<1" \
        "httpx>=0.28,<1" \
        "pydantic>=2.6,<3" \
        "pyyaml>=6.0,<7" \
        "uvicorn[standard]>=0.30,<1"

# --- Non-root user ----------------------------------------------------------
RUN useradd -m -u 1000 -s /bin/bash mars

# --- App source -------------------------------------------------------------
# Runtime source (including the schema module) gets copied as a single
# root so the supervisor's imports match what tests use on the host.
WORKDIR /app
COPY --chown=mars:mars apps/mars-runtime/src /app/runtime-src

# Entrypoint script (graceful shutdown, env defaults)
COPY --chown=mars:mars apps/mars-runtime/start.sh /app/start.sh
RUN chmod +x /app/start.sh

# --- Claude Code security settings + PreToolUse hook scripts ---------------
# The baked-in settings.json wires two PreToolUse command hooks (Story 3.2).
# The scripts read tool input from stdin and exit 2 to deny:
#   * deny-protected-edit.sh: blocks Edit/Write/MultiEdit on CLAUDE.md,
#     AGENTS.md, claude_code_settings.json (prompt immutability).
#   * deny-secret-read-bash.sh: blocks Bash commands matching
#     env / printenv / echo $ / bare `set` (secret-read speed bump).
# The supervisor passes --settings /app/claude_code_settings.json when
# spawning ``claude`` via the MARS_CLAUDE_CODE_SETTINGS env var below.
COPY --chown=mars:mars apps/mars-runtime/claude_code_settings.json /app/claude_code_settings.json
COPY --chown=mars:mars apps/mars-runtime/hooks /app/hooks
RUN chmod +x /app/hooks/*.sh

USER mars

# PYTHONPATH mirrors the pytest pythonpath on the host: mars-runtime src
# provides all supervisor-level imports (events, session, supervisor,
# schema).
#
# MARS_CLAUDE_CODE_SETTINGS is read by
# ``session.claude_code.spawn_claude_code`` and passed as ``--settings``
# to every ``claude -p`` invocation, activating the baked PreToolUse
# hooks.
ENV PYTHONPATH="/app/runtime-src" \
    PORT=8080 \
    MARS_CLAUDE_CODE_SETTINGS="/app/claude_code_settings.json"

EXPOSE 8080

# tini reaps zombies and forwards SIGTERM → uvicorn → supervisor
ENTRYPOINT ["/usr/bin/tini", "--"]
CMD ["/app/start.sh"]
