{
  "name": "mars-daemons",
  "version": "0.3.0",
  "description": "Enterprise claude code — TypeScript client for mars-daemons HTTP API (sessions, SSE streaming, file exchange).",
  "keywords": [
    "agent",
    "llm",
    "claude",
    "anthropic",
    "openai",
    "mars",
    "mars-daemons",
    "enterprise",
    "sse",
    "coding-agent"
  ],
  "homepage": "https://github.com/TacosyHorchata/mars-daemons",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TacosyHorchata/mars-daemons.git",
    "directory": "clients/typescript"
  },
  "bugs": {
    "url": "https://github.com/TacosyHorchata/mars-daemons/issues"
  },
  "license": "Apache-2.0",
  "author": "Pedro Rios <priosabarca@gmail.com>",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "@types/node": "^20.0.0"
  }
}
